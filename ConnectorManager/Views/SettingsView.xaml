<UserControl x:Class="ConnectorManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ConnectorManager.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel MaxWidth="700">
            <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <!-- Auto-Detect -->
            <GroupBox Header="Repository Detection" Margin="0,0,0,16" Padding="12">
                <StackPanel Orientation="Horizontal">
                    <Button Content="📂 Auto-Detect Repos" Command="{Binding AutoDetectCommand}"
                            Padding="12,4"/>
                    <TextBlock Text="  Browse to workspace root to detect CMB repos"
                               Foreground="#888" VerticalAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <!-- Authentication -->
            <GroupBox Header="Authentication" Margin="0,0,0,16" Padding="12">
                <StackPanel>
                    <TextBlock Text="Authorization header value:" Margin="0,0,0,2"/>
                    <TextBlock Text="e.g. Basic dXNlcjpwYXNz  or  Bearer eyJhbGci..."
                               Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding AuthorizationHeader, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" Margin="0,0,0,12"
                             TextWrapping="Wrap" AcceptsReturn="False" MaxHeight="60"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Mono,Consolas"/>
                </StackPanel>
            </GroupBox>

            <!-- Elastic GlobalSearch -->
            <GroupBox Header="Elastic GlobalSearch (Sample Data)" Margin="0,0,0,16" Padding="12">
                <StackPanel>
                    <TextBlock Text="Credentials for direct Elasticsearch API search. Same as CMB.Core GlobalSearch config."
                               Foreground="#888" FontSize="11" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="User ID:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ElasticUserId, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" Margin="0,0,0,6" FontFamily="Cascadia Mono,Consolas"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="ElasticPasswordBox"
                                     Padding="6,4" Margin="0,0,0,6"
                                     PasswordChanged="ElasticPasswordBox_PasswordChanged"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Region:" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  SelectedItem="{Binding ElasticRegion}"
                                  Padding="6,4" Margin="0,0,0,0" HorizontalAlignment="Left" Width="120">
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">APAC</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">AMER</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">EMEA</sys:String>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="💾 Save Settings" Command="{Binding SaveCommand}"
                        Padding="16,8" Background="#2D7D46" Foreground="White" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="16,0,0,0"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
