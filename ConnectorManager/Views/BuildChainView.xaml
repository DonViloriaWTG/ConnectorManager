<UserControl x:Class="ConnectorManager.Views.BuildChainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ConnectorManager.ViewModels"
             xmlns:converters="clr-namespace:ConnectorManager.Converters">
    <UserControl.Resources>
        <Style x:Key="StepStatusStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Repository Paths -->
        <GroupBox Grid.Row="0" Header="Repository Paths" Margin="0,0,0,10" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Common -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="CMB.Common:" VerticalAlignment="Center"
                           Margin="0,0,8,4" FontWeight="SemiBold" FontSize="12"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CommonRepoPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3" Margin="0,0,4,4" FontSize="12"/>
                <Button Grid.Row="0" Grid.Column="2" Content="..." Command="{Binding BrowseCommonCommand}"
                        Padding="8,2" Margin="0,0,0,4" MinWidth="30"/>

                <!-- Framework -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="CMB.Framework:" VerticalAlignment="Center"
                           Margin="0,0,8,4" FontWeight="SemiBold" FontSize="12"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FrameworkRepoPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3" Margin="0,0,4,4" FontSize="12"/>
                <Button Grid.Row="1" Grid.Column="2" Content="..." Command="{Binding BrowseFrameworkCommand}"
                        Padding="8,2" Margin="0,0,0,4" MinWidth="30"/>

                <!-- Core -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="CMB.Core:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontWeight="SemiBold" FontSize="12"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CoreRepoPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3" Margin="0,0,4,0" FontSize="12"/>
                <Button Grid.Row="2" Grid.Column="2" Content="..." Command="{Binding BrowseCoreCommand}"
                        Padding="8,2" MinWidth="30"/>
            </Grid>
        </GroupBox>

        <!-- Header and Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Build Chain: Common → Framework → Core"
                       FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="▶ Build All" Command="{Binding BuildAllCommand}" Margin="24,0,8,0"
                    Padding="16,6" FontWeight="SemiBold"
                    Background="#2D7D46" Foreground="White"/>
            <Button Content="✖ Cancel" Command="{Binding CancelBuildCommand}" Margin="4,0"
                    Padding="12,6"/>
            <Button Content="📋 Copy Log" Command="{Binding CopyLogCommand}" Margin="4,0"
                    Padding="12,6"/>
        </StackPanel>

        <!-- Build Steps -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Steps}" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:BuildStepViewModel}">
                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                       Style="{StaticResource StepStatusStyle}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" FontSize="11"
                                           Foreground="#888"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Status}"
                                       VerticalAlignment="Center" Foreground="#888"
                                       FontSize="12"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Output Log -->
        <GroupBox Grid.Row="3" Header="Build Output" Margin="0,0,0,8">
            <TextBox Text="{Binding OutputLogText, Mode=OneWay}"
                     FontFamily="Cascadia Mono,Consolas,Courier New"
                     FontSize="12" IsReadOnly="True"
                     AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     converters:AutoScrollBehavior.IsEnabled="True"/>
        </GroupBox>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#F5F5F5" Padding="8,4" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"/>
                <TextBlock Text=" — " Foreground="#888"
                           Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding CurrentStepName}" Foreground="#888"
                           Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
