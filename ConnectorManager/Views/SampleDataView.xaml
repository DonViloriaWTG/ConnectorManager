<UserControl x:Class="ConnectorManager.Views.SampleDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ConnectorManager.ViewModels"
             xmlns:converters="clr-namespace:ConnectorManager.Converters">
    <UserControl.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBool"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Header -->
            <RowDefinition Height="Auto"/>      <!-- Search options -->
            <RowDefinition Height="*"/>         <!-- Results area -->
            <RowDefinition Height="Auto"/>      <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="📊 Sample Data" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Search Elastic GlobalSearch (Kibana) for connector request samples"
                       Foreground="#888" Margin="0,2,0,0" FontSize="12"/>
        </StackPanel>

        <!-- Search Options -->
        <GroupBox Grid.Row="1" Margin="0,0,0,8" Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1: Connector + Environment + Time Range -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Connector:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" IsEditable="True"
                              Text="{Binding ConnectorName, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding ConnectorNames}"
                              IsTextSearchEnabled="True"
                              FontSize="13" Padding="4,4" VerticalAlignment="Center"
                              ToolTip="Type a connector name or select from the dropdown (populated after scanning on Deploy tab)"/>

                    <TextBlock Grid.Column="3" Text="Environment:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <StackPanel Grid.Column="4" Orientation="Vertical" VerticalAlignment="Center">
                        <RadioButton Content="Staging" FontSize="12"
                                     IsChecked="{Binding SelectedEnvironment,
                                         Converter={StaticResource EnumToBool},
                                         ConverterParameter={x:Static vm:SearchEnvironment.Staging}}"/>
                        <RadioButton Content="Production" FontSize="12"
                                     IsChecked="{Binding SelectedEnvironment,
                                         Converter={StaticResource EnumToBool},
                                         ConverterParameter={x:Static vm:SearchEnvironment.Production}}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="6" Text="Time Range:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="7" ItemsSource="{Binding TimeRangeOptions}"
                              DisplayMemberPath="Value" SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedTimeRange}"
                              FontSize="12" Padding="4,3" VerticalAlignment="Center"/>
                </Grid>

                <!-- Row 2: Elastic credentials + Region + Max results -->
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="User ID:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1" Text="{Binding ElasticUserId, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12" Padding="4,3" VerticalAlignment="Center"
                             FontFamily="Cascadia Mono,Consolas"
                             ToolTip="Elasticsearch user ID (from Settings → Elastic GlobalSearch)"/>

                    <TextBlock Grid.Column="3" Text="Password:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <PasswordBox Grid.Column="4" x:Name="ElasticPasswordBox"
                                 FontSize="12" Padding="4,3" VerticalAlignment="Center"
                                 ToolTip="Elasticsearch password (from Settings → Elastic GlobalSearch)"
                                 PasswordChanged="ElasticPasswordBox_PasswordChanged"/>

                    <TextBlock Grid.Column="6" Text="Region:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="7" ItemsSource="{Binding RegionOptions}"
                              SelectedItem="{Binding ElasticRegion}"
                              FontSize="12" Padding="4,3" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="9" Text="Max:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="10" Text="{Binding MaxResults, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12" Padding="4,3" VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- Row 3: Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="🔍 Search" Command="{Binding SearchElasticCommand}"
                            Padding="14,6" FontSize="13" FontWeight="SemiBold"
                            ToolTip="Search Elasticsearch directly using Basic Auth credentials"/>

                    <Border Width="1" Background="#CCC" Margin="12,2"/>

                    <Button Content="🌐 Open in Kibana" Command="{Binding OpenInKibanaCommand}"
                            Padding="14,6" FontSize="13" Margin="4,0,0,0"
                            ToolTip="Opens the search in your default browser (uses your existing Kibana session)"/>
                    <Button Content="📋 Copy URL" Command="{Binding CopyUrlCommand}"
                            Padding="14,6" FontSize="13" Margin="8,0,0,0"/>

                    <!-- Searching indicator -->
                    <TextBlock Text="⏳ Searching..." VerticalAlignment="Center"
                               Foreground="#666" Margin="12,0,0,0" FontSize="12"
                               Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Results Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Results list -->
            <GroupBox Grid.Column="0" Header="Results" Padding="4">
                <ListBox ItemsSource="{Binding Results}"
                         SelectedItem="{Binding SelectedResult}"
                         DisplayMemberPath="Summary"
                         FontFamily="Consolas" FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </GroupBox>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#DDD" ResizeBehavior="PreviousAndNext"/>

            <!-- Right: Request Data viewer / paste area -->
            <GroupBox Grid.Column="2" Padding="4">
                <GroupBox.Header>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Request Data" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <Button Content="📋 Copy" DockPanel.Dock="Right"
                                Command="{Binding CopyRequestDataCommand}"
                                Padding="10,3" FontSize="11" Margin="8,0,0,0"/>
                        <Button Content="🗑 Clear" DockPanel.Dock="Right"
                                Command="{Binding ClearRequestDataCommand}"
                                Padding="10,3" FontSize="11" Margin="4,0,0,0"/>
                    </DockPanel>
                </GroupBox.Header>
                <TextBox Text="{Binding RequestDataContent, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" AcceptsTab="True"
                         FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="#FAFAFA" Padding="6,4"
                         ToolTip="Displays request data from API search results, or paste data copied from Kibana here."/>
            </GroupBox>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="3" Text="{Binding StatusText}"
                   Foreground="#666" Margin="0,6,0,0" FontSize="12"/>
    </Grid>
</UserControl>
