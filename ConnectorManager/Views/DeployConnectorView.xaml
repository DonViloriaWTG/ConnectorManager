<UserControl x:Class="ConnectorManager.Views.DeployConnectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ConnectorManager.Models"
             xmlns:converters="clr-namespace:ConnectorManager.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:StringToBrushConverter x:Key="StringToBrush"/>
        <converters:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Repository Path -->
        <GroupBox Grid.Row="0" Header="Repository Path" Margin="0,0,0,10" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CMB.CarrierConnector:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontWeight="SemiBold" FontSize="12"/>
                <TextBox Grid.Column="1" Text="{Binding CarrierConnectorRepoPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3" FontSize="12" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="..." Width="30" Margin="4,0,0,0"
                        Command="{Binding BrowseCarrierConnectorCommand}" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- Header + Scan -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Deploy Connector" FontSize="18" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Content="🔍 Scan Connectors" Command="{Binding ScanConnectorsCommand}"
                    Margin="24,0,8,0" Padding="12,6"/>
            <TextBlock Text="{Binding ConnectorCount, StringFormat='{}{0} connectors'}"
                       VerticalAlignment="Center" Foreground="#888" Margin="8,0"/>
        </StackPanel>

        <!-- Search + Results + Special Details -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Search / Region Navigation -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Search connectors:" Margin="0,0,0,4"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" FontSize="14"/>

                <!-- Back button (visible when a region is selected) -->
                <Button Content="← Back to Regions" Command="{Binding BackToRegionsCommand}"
                        Margin="0,6,0,0" Padding="8,4" HorizontalAlignment="Left"
                        Visibility="{Binding SelectedRegion, Converter={StaticResource NullToCollapsed}}"/>

                <!-- Region tiles in 4-column grid (visible when connector list is NOT shown) -->
                <ItemsControl ItemsSource="{Binding Regions}" Margin="0,6,0,0"
                              Visibility="{Binding ShowConnectorList, Converter={StaticResource InvBoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectRegionCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="3" Padding="0" Cursor="Hand"
                                    BorderThickness="1" BorderBrush="#CCC"
                                    Background="White">
                                <StackPanel HorizontalAlignment="Center" Margin="6,8">
                                    <!-- Flag image (for country regions) -->
                                    <Image Source="{Binding FlagPath}" Width="48" Height="32"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           HorizontalAlignment="Center">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGlobe}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <!-- Globe icon (for Global / International) -->
                                    <TextBlock Text="🌐" FontSize="26" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGlobe}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Region name -->
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- Connector count -->
                                    <TextBlock Text="{Binding ConnectorCount, StringFormat='{}{0}'}"
                                               Foreground="#888" FontSize="10"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Connector list (visible when searching or region selected) -->
                <ListBox ItemsSource="{Binding SearchResults}"
                         SelectedItem="{Binding SelectedConnector}"
                         MaxHeight="280" Margin="0,4,0,0"
                         DisplayMemberPath="DisplayName"
                         Visibility="{Binding ShowConnectorList, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- Selected Connector Details -->
            <Border Grid.Column="2" Background="#F8F8F8" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Selected Connector" FontWeight="SemiBold" FontSize="14"
                               Margin="0,0,0,8"/>

                    <TextBlock Margin="0,2">
                        <Run Text="Name: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SelectedConnector.Name, Mode=OneWay, FallbackValue='-'}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <Run Text="Region: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SelectedConnector.Region, Mode=OneWay, FallbackValue='-'}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <Run Text="Version: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SelectedConnector.VersionPrefix, Mode=OneWay, FallbackValue='-'}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <Run Text="Carrier Code: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SelectedConnector.DeploymentInfo.CarrierCode, Mode=OneWay, FallbackValue='-'}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" TextWrapping="Wrap" FontSize="11" Foreground="#888">
                        <Run Text="Project: "/>
                        <Run Text="{Binding SelectedConnector.ProjectPath, Mode=OneWay, FallbackValue='-'}"/>
                    </TextBlock>

                    <!-- Version Override -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Version override (leave blank for auto):"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding VersionOverride, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" FontSize="12" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Authorization Header -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Authorization:" FontSize="12" Margin="0,0,0,2"/>
                        <TextBlock Text="e.g. Basic dXNlcjpwYXNz" Foreground="#888" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding AuthorizationHeader, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" FontSize="12" HorizontalAlignment="Stretch"
                                 FontFamily="Cascadia Mono,Consolas" TextWrapping="Wrap"
                                 MaxHeight="40" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Special Details Override -->
            <GroupBox Grid.Column="4">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Special Details" VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <Button Content="↩ Reset" Command="{Binding ResetSpecialDetailsCommand}"
                                Padding="8,2" Margin="12,0,0,0" FontSize="11"
                                ToolTip="Reset to original values from source"/>
                    </StackPanel>
                </GroupBox.Header>
                <TextBox Text="{Binding SpecialDetailsContent, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Cascadia Mono,Consolas,Courier New"
                         FontSize="11" AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         BorderThickness="0"/>
            </GroupBox>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="🔨 Build Only" Command="{Binding BuildConnectorCommand}"
                    Padding="14,6" Margin="0,0,8,0"/>
            <Button Content="🚀 Build &amp; Upload" Command="{Binding BuildAndUploadCommand}"
                    Padding="14,6" Margin="0,0,8,0"
                    Background="#2D7D46" Foreground="White" FontWeight="SemiBold"/>
            <Button Content="🐛 Debug" Command="{Binding DebugConnectorCommand}"
                    Padding="14,6" Margin="0,0,8,0"
                    Background="#8B5CF6" Foreground="White" FontWeight="SemiBold"
                    ToolTip="Build in Debug config and restart API in debug mode for this connector"/>
            <Button Content="✖ Cancel" Command="{Binding CancelCommand}"
                    Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="📋 Copy Log" Command="{Binding CopyLogCommand}"
                    Padding="12,6"/>
        </StackPanel>

        <!-- Output Log -->
        <GroupBox Grid.Row="4" Header="Deploy Output" Margin="0,0,0,8">
            <TextBox Text="{Binding OutputLogText, Mode=OneWay}"
                     FontFamily="Cascadia Mono,Consolas,Courier New"
                     FontSize="12" IsReadOnly="True"
                     AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     converters:AutoScrollBehavior.IsEnabled="True"/>
        </GroupBox>

        <!-- Status -->
        <Border Grid.Row="5" Background="#F5F5F5" Padding="8,4" CornerRadius="4">
            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</UserControl>
