<UserControl x:Class="ConnectorManager.Views.ApiManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ConnectorManager.Converters">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="CMB API Manager"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <!-- Controls -->
        <Border Grid.Row="1" Background="#F8F8F8" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status indicator -->
                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,24,8">
                    <Ellipse Width="14" Height="14" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CCC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusText}" Value="Running">
                                        <Setter Property="Fill" Value="#2D7D46"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="Starting...">
                                        <Setter Property="Fill" Value="#F0AD4E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- URL display -->
                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="URL: " Foreground="#888" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ApiUrl}" FontFamily="Cascadia Mono,Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,0,8">
                    <Button Content="▶ Start" Command="{Binding StartApiCommand}"
                            Padding="14,6" Margin="0,0,6,0"
                            Background="#2D7D46" Foreground="White"/>
                    <Button Content="⏹ Stop" Command="{Binding StopApiCommand}"
                            Padding="14,6" Margin="0,0,6,0"/>
                    <Button Content="🔄 Restart" Command="{Binding RestartApiCommand}"
                            Padding="14,6"/>
                    <Button Content="📋 Copy Log" Command="{Binding CopyLogCommand}"
                            Padding="14,6" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Core repo path -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="Core Repo: " Foreground="#888" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding CoreRepoPath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Mono,Consolas" FontSize="11"
                             MinWidth="400" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Content="📂" Command="{Binding BrowseCoreRepoCommand}"
                            Padding="6,2" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: Output Log + Payload Viewer side by side -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Output Log (left) -->
            <GroupBox Grid.Column="0" Header="API Output">
                <TextBox Text="{Binding OutputLogText, Mode=OneWay}"
                         FontFamily="Cascadia Mono,Consolas,Courier New"
                         FontSize="12" IsReadOnly="True"
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         converters:AutoScrollBehavior.IsEnabled="True"/>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#DDD" Cursor="SizeWE"/>

            <!-- Captured Payloads (right) -->
            <GroupBox Grid.Column="2">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Carrier Payloads" VerticalAlignment="Center"/>
                        <Button Content="📋 Copy" Command="{Binding CopyPayloadCommand}"
                                Padding="8,2" Margin="12,0,4,0" FontSize="11"/>
                        <Button Content="🗑 Clear" Command="{Binding ClearPayloadsCommand}"
                                Padding="8,2" FontSize="11"/>
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MaxHeight="180"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Payload list -->
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding CapturedPayloads}"
                             SelectedItem="{Binding SelectedPayload}"
                             FontFamily="Cascadia Mono,Consolas" FontSize="11"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayHeader}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                  Background="#DDD" Cursor="SizeNS"/>

                    <!-- Payload content -->
                    <TextBox Grid.Row="2"
                             Text="{Binding SelectedPayload.Content, Mode=OneWay, FallbackValue=''}"
                             FontFamily="Cascadia Mono,Consolas,Courier New"
                             FontSize="12" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             BorderThickness="0"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
